# Local Postgres settings for Aurum.
# docker-compose.yml uses the same names, with these defaults.
AURUM_POSTGRES_HOST=localhost
AURUM_POSTGRES_PORT=5433
AURUM_POSTGRES_DB=aurum
AURUM_POSTGRES_USER=aurum
AURUM_POSTGRES_PASSWORD=aurum

# Optional: full connection string for remote/cloud Postgres (e.g. Neon).
# When set, DATABASE_URL takes precedence over the AURUM_POSTGRES_* vars above.
# Uncomment and replace placeholders — do not commit a real URL.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
